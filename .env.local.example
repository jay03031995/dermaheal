# ----------------------------------------------------------------------------
# Sanity (admin panel at /studio)
# ----------------------------------------------------------------------------
# After creating a project at https://www.sanity.io/manage:
#   1. Copy the Project ID from the project page.
#   2. Use the default dataset name (production) unless you changed it.
#   3. Create an API token under "API → Tokens" with "Editor" permissions
#      and paste it as SANITY_API_TOKEN. The token is required only by the
#      seed script — never expose it client-side.
# ----------------------------------------------------------------------------

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-11-01

# Server-only — never commit a real value here.
SANITY_API_TOKEN=
